generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  VIEWER
}

enum WorkOrderStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
  REOPENED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkOrderType {
  INSTALLATION
  MAINTENANCE
  REPAIR
  REMOVAL
  SURVEY
  OTHER
}

enum CrewStatus {
  AVAILABLE
  BUSY
  ON_BREAK
  OFFLINE
}

enum TechnicianStatus {
  AVAILABLE
  BUSY
  ON_BREAK
  OFFLINE
}

enum VehicleType {
  TRUCK
  VAN
  MOTORCYCLE
  BICYCLE
  OTHER
}

// ============ USUARIOS Y SEGURIDAD ============

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  avatar        String?
  role          UserRole   @default(SUPERVISOR)
  isActive      Boolean    @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  assignedOrders WorkOrder[]  @relation("AssignedOrders")
  createdOrders  WorkOrder[]  @relation("CreatedOrders")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ============ ÓRDENES DE TRABAJO ============

model WorkOrder {
  id              String           @id @default(uuid())
  externalId      String?          @unique
  orderNumber     String           @unique
  title           String
  description     String?
  status          WorkOrderStatus  @default(PENDING)
  priority        WorkOrderPriority @default(MEDIUM)
  type            WorkOrderType    @default(MAINTENANCE)
  source          String?          // Origen: ticket, manual, recurrente
  estimatedTime   Int?             // Minutos estimados
  totalTime       Int?             // Minutos reales
  scheduledDate   DateTime?
  scheduledStart  DateTime?
  scheduledEnd    DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancellationReason String?
  diagnosis       String?
  resolution      String?
  notes           String?

  // Relaciones
  customerId      String
  customer        Customer         @relation(fields: [customerId], references: [id])
  addressId       String?
  address         CustomerAddress? @relation(fields: [addressId], references: [id])
  assignedToId    String?
  assignedTo      User?            @relation("AssignedOrders", fields: [assignedToId], references: [id])
  createdById     String
  createdBy       User             @relation("CreatedOrders", fields: [createdById], references: [id])
  crewId          String?
  crew            Crew?            @relation(fields: [crewId], references: [id])
  slaId           String?
  sla             SLA?             @relation(fields: [slaId], references: [id])

  // Checklist
  checklistItems  ChecklistItem[]

  // Materiales
  materials       WorkOrderMaterial[]

  // Multimedia
  photos          Photo[]
  signature       Signature?

  // Timeline
  statusHistory   WorkOrderStatusHistory[]
  timeline        TimelineEntry[]

  // Auditoría
  auditLogs       AuditLog[]

  // Ubicación
  latitude        Float?
  longitude       Float?
  location        Unsupported("geometry(Point, 4326)")?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([priority])
  @@index([customerId])
  @@index([crewId])
  @@index([assignedToId])
  @@index([scheduledDate])
  @@map("work_orders")
}

model WorkOrderStatusHistory {
  id        String          @id @default(uuid())
  orderId   String
  order     WorkOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus WorkOrderStatus?
  toStatus  WorkOrderStatus
  changedBy String
  reason    String?
  createdAt DateTime        @default(now())

  @@index([orderId])
  @@map("work_order_status_history")
}

model TimelineEntry {
  id        String     @id @default(uuid())
  orderId   String
  order     WorkOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      String     // system, user, technician, note
  title     String
  description String?
  userId    String?
  createdAt DateTime   @default(now())

  @@index([orderId])
  @@map("timeline_entries")
}

model ChecklistItem {
  id          String     @id @default(uuid())
  orderId     String
  order       WorkOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  label       String
  required    Boolean    @default(false)
  completed   Boolean    @default(false)
  completedAt DateTime?
  completedBy String?
  sortOrder   Int        @default(0)

  @@index([orderId])
  @@map("checklist_items")
}

model WorkOrderMaterial {
  id         String   @id @default(uuid())
  orderId    String
  order      WorkOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  quantity   Int      @default(1)
  unitPrice  Decimal? @db.Decimal(10, 2)
  createdAt  DateTime @default(now())

  @@index([orderId])
  @@map("work_order_materials")
}

model Photo {
  id        String     @id @default(uuid())
  orderId   String
  order     WorkOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  url       String
  thumbnail String?
  type      String?    // before, during, after, signature
  label     String?
  latitude  Float?
  longitude Float?
  createdAt DateTime   @default(now())

  @@index([orderId])
  @@map("photos")
}

model Signature {
  id        String     @id @default(uuid())
  orderId   String     @unique
  order     WorkOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  url       String
  name      String?
  document  String?    // Tipo de documento
  documentNumber String?
  createdAt DateTime   @default(now())

  @@map("signatures")
}

// ============ CUADRILLAS ============

model Crew {
  id            String       @id @default(uuid())
  name          String       @unique
  code          String       @unique
  description   String?
  status        CrewStatus   @default(AVAILABLE)
  specialty     String?      // Fibra, Cobre, Radio, Mixto
  zone          String?      // Zona de operación
  latitude      Float?
  longitude     Float?
  location      Unsupported("geometry(Point, 4326)")?
  lastGpsUpdate DateTime?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  technicians   Technician[]
  vehicle       Vehicle?
  inventory     Inventory[]
  workOrders    WorkOrder[]

  @@index([status])
  @@index([zone])
  @@map("crews")
}

model Technician {
  id            String           @id @default(uuid())
  firstName     String
  lastName      String
  email         String?          @unique
  phone         String
  documentType  String?          // DNI, Pasaporte
  documentNumber String?
  status        TechnicianStatus @default(AVAILABLE)
  specialty     String?
  latitude      Float?
  longitude     Float?
  location      Unsupported("geometry(Point, 4326)")?
  lastGpsUpdate DateTime?
  isActive      Boolean          @default(true)
  crewId        String
  crew          Crew             @relation(fields: [crewId], references: [id])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([crewId])
  @@index([status])
  @@map("technicians")
}

model Vehicle {
  id          String      @id @default(uuid())
  brand       String
  model       String
  plate       String      @unique
  type        VehicleType @default(VAN)
  year        Int?
  color       String?
  isActive    Boolean     @default(true)
  crewId      String      @unique
  crew        Crew        @relation(fields: [crewId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("vehicles")
}

model Inventory {
  id          String   @id @default(uuid())
  crewId      String
  crew        Crew     @relation(fields: [crewId], references: [id], onDelete: Cascade)
  materialId  String
  material    Material @relation(fields: [materialId], references: [id])
  quantity    Int      @default(0)
  minQuantity Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([crewId, materialId])
  @@map("inventory")
}

model Material {
  id          String             @id @default(uuid())
  code        String             @unique
  name        String
  description String?
  category    String?
  unit        String             // unidad, metro, pieza, etc
  unitPrice   Decimal?           @db.Decimal(10, 2)
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  inventory   Inventory[]
  workOrders  WorkOrderMaterial[]

  @@map("materials")
}

// ============ CLIENTES ============

model Customer {
  id            String            @id @default(uuid())
  externalId    String?           @unique
  documentType  String?           // DNI, RUC, Pasaporte
  documentNumber String?
  firstName     String
  lastName      String
  businessName  String?
  email         String?
  phone         String
  phone2        String?
  notes         String?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  addresses     CustomerAddress[]
  equipments    Equipment[]
  workOrders    WorkOrder[]

  @@index([documentNumber])
  @@index([phone])
  @@map("customers")
}

model CustomerAddress {
  id           String     @id @default(uuid())
  customerId   String
  customer     Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  street       String
  number       String?
  complement   String?
  neighborhood String?
  city         String
  state        String?
  zipCode      String?
  latitude     Float?
  longitude    Float?
  location     Unsupported("geometry(Point, 4326)")?
  isMain       Boolean    @default(false)
  label        String?    // Casa, Trabajo, etc
  notes        String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  workOrders   WorkOrder[]

  @@index([customerId])
  @@map("customer_addresses")
}

model Equipment {
  id            String     @id @default(uuid())
  customerId    String
  customer      Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type          String     // ONT, Router, Decodificador, etc
  brand         String?
  model         String?
  serialNumber  String?
  macAddress    String?
  status        String?    // Instalado, Averiado, Retirado
  installedAt   DateTime?
  removedAt     DateTime?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([customerId])
  @@index([serialNumber])
  @@map("equipments")
}

// ============ SLA ============

model SLA {
  id          String   @id @default(uuid())
  name        String
  description String?
  priority    WorkOrderPriority
  type        WorkOrderType
  responseTime Int     // Minutos para respuesta
  resolveTime  Int     // Minutos para resolución
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workOrders  WorkOrder[]

  @@unique([priority, type])
  @@map("slas")
}

// ============ AUDITORÍA ============

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // CREATE, UPDATE, DELETE, ASSIGN, STATUS_CHANGE, LOGIN
  entity    String   // work_order, crew, customer, user, etc
  entityId  String?
  orderId   String?
  order     WorkOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  metadata  Json?    // Detalles del cambio
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([orderId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============ NOTIFICACIONES ============

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  title     String
  message   String?
  type      String   // info, warning, success, error
  read      Boolean  @default(false)
  link      String?  // Ruta a la que redirige
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@map("notifications")
}

// ============ CONFIGURACIÓN ============

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  category  String?  // general, integration, notifications, etc
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}